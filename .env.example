# PrimeHome — Environment Configuration Example
# Copy this file to .env and fill in the real values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
# Railway MySQL: copy from Railway dashboard → MySQL service → Connect tab
# Local XAMPP example: mysql://root@127.0.0.1:3307/primehome
DATABASE_URL=mysql://user:password@host:port/primehome

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string_in_production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://primehome.lb,https://www.primehome.lb,https://your-app.vercel.app

# ─── Frontend ─────────────────────────────────────────────────────────────────
# The base URL of the remote Railway backend API server
VITE_API_URL=https://your-backend-production.up.railway.app

